# chain
RPC_URL=http://localhost:8545
CHAIN_ID=31337
# anvil account[0] private key — LOCAL TEST ONLY, never use on a real network
RELAYER_PK=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# localstack / aws
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=agent-cards
KMS_KEY_ALIAS=alias/agent-master
DDB_TABLE=agents
SQS_QUEUE=settle

# model (M2) — backend-pluggable gateway.
#   stub     = deterministic, no model (default; used by tests, needs nothing)
#   llamacpp = OpenAI-compatible llama.cpp server CONTAINER (CPU), started via `make model`
MODEL_BACKEND=stub
MODEL_BASE_URL=http://localhost:8081/v1
MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct-GGUF
# GGUF the llama.cpp container downloads (repo:quant). Override for a smaller/faster model, e.g.
#   Qwen/Qwen2.5-0.5B-Instruct-GGUF:Q4_K_M
MODEL_GGUF=Qwen/Qwen2.5-1.5B-Instruct-GGUF:Q4_K_M
