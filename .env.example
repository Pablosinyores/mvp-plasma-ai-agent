# chain
RPC_URL=http://localhost:8545
CHAIN_ID=31337
# anvil account[0] private key — LOCAL TEST ONLY, never use on a real network
RELAYER_PK=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# localstack / aws
AWS_ENDPOINT_URL=http://localhost:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
S3_BUCKET=agent-cards
KMS_KEY_ALIAS=alias/agent-master
DDB_TABLE=agents
SQS_QUEUE=settle

# gas abstraction (M8) — gasless single-token UX via EIP-7702 + ERC-4337.
#   ENTRYPOINT_ADDRESS : canonical ERC-4337 EntryPoint v0.7 (same address on every chain).
#   PAYMASTER_ADDRESS  : the verifying/token paymaster that sponsors gas (blank => none deployed yet).
#   GAS_TIER selects how the user pays for gas:
#     native-float = user holds native gas + USDT (baseline, no abstraction)  [default]
#     usdt-as-gas  = USDT is the gas token; no native float needed
#     7702-4337    = EOA delegates (EIP-7702) to a smart account and an ERC-4337 paymaster sponsors
#                    gas, settling spend in USDT — fully gasless, single token
ENTRYPOINT_ADDRESS=0x0000000071727De22E5E9d8BAf0edAc6f37da032
PAYMASTER_ADDRESS=
GAS_TIER=native-float

# model (M2) — backend-pluggable gateway.
#   stub     = deterministic, no model (default; used by tests, needs nothing)
#   llamacpp = OpenAI-compatible llama.cpp server CONTAINER (CPU), started via `make model`
MODEL_BACKEND=stub
MODEL_BASE_URL=http://localhost:8081/v1
MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct-GGUF
# GGUF the llama.cpp container downloads (repo:quant). Override for a smaller/faster model, e.g.
#   Qwen/Qwen2.5-0.5B-Instruct-GGUF:Q4_K_M
MODEL_GGUF=Qwen/Qwen2.5-1.5B-Instruct-GGUF:Q4_K_M
